<?xml version="1.0" encoding="UTF-8"?>
<manifest>
  <remote name="noll" fetch="https://github.com/noll-OS" revision="master"/>
  <remove-project name="platform_packages_apps_Updater"/>
  <remove-project name="platform_build"/>

  <project path="vendor/noll" name="vendor" remote="noll"/>
  <project path="packages/apps/Updater" name="app-updater" remote="noll"/>
  <project path="build/make" name="build" remote="noll" groups="pdk,sysui-studio">
    <linkfile src="CleanSpec.mk" dest="build/CleanSpec.mk"/>
    <linkfile src="buildspec.mk.default" dest="build/buildspec.mk.default"/>
    <linkfile src="core" dest="build/core"/>
    <linkfile src="envsetup.sh" dest="build/envsetup.sh"/>
    <linkfile src="target" dest="build/target"/>
    <linkfile src="tools" dest="build/tools"/>
  </project>
</manifest>
